{
  "uid": "gp-gateways",
  "title": "GlobalProtect Gateways",
  "tags": ["panos", "globalprotect"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Connected users per gateway",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "panos_gp_current_users",
          "legendFormat": "{{device}} / {{gateway}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Fleet total connected users",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum(panos_gp_current_users)",
          "legendFormat": "Connected users"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Current per-gateway counts",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Current users", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "panos_gp_current_users",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "panos_gp_unique_users",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "exclude": { "names": ["__name__"] } } },
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "device": "Device",
              "gateway": "Gateway",
              "site": "Site",
              "Value #A": "Current users",
              "Value #B": "Unique users"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Connector health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "panels": []
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Connector up",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 70 },
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Down", "color": "red", "index": 1 },
                "1": { "text": "Up", "color": "green", "index": 0 }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "panos_connector_up",
          "legendFormat": "{{device}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scrape duration",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "min": 0,
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "panos_connector_scrape_duration_seconds",
          "legendFormat": "{{device}}"
        }
      ]
    }
  ]
}
