# Copy to .env and fill in. Never commit .env.

# Where the connector pushes metrics (service name on the compose network).
VM_URL=http://victoriametrics:8428

# Grafana admin password (user: admin).
GRAFANA_ADMIN_PASSWORD=

# Shared PAN-OS API key. Override per device with
# PANOS_API_KEY__<NAME> (device name uppercased, '-' -> '_'),
# e.g. PANOS_API_KEY__FW_EAST_01=...
PANOS_API_KEY=

# true | false | /path/to/ca-bundle.pem
PANOS_VERIFY_TLS=true

# Seconds between poll cycles.
POLL_INTERVAL=60

# Uncomment to log raw PAN-OS structures on parse failures.
# LOG_LEVEL=DEBUG
